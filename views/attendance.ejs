<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Attendance</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { background: #0f172a; color: #e2e8f0; font-family: 'Segoe UI', Inter, system-ui, sans-serif; min-height: 100vh; }
    .page { min-height: 100vh; display: grid; place-items: center; padding: 24px; }
    .form-card {
      width: min(780px, 100%);
      background: #111827;
      border-radius: 24px;
      border: 1px solid rgba(148, 163, 184, 0.12);
      padding: 36px 32px;
      box-shadow: 0 8px 32px rgba(0,0,0,0.4);
    }
    .card-header { margin-bottom: 28px; }
    .card-header h1 { font-size: clamp(1.4rem, 3vw, 2rem); font-weight: 700; color: #f1f5f9; }
    .card-header p { color: #94a3b8; font-size: 0.92rem; margin-top: 6px; }
    .quick-links { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 28px; }
    .link-btn {
      padding: 10px 20px;
      border-radius: 10px;
      border: 1px solid #334155;
      background: #1e293b;
      color: #94a3b8;
      text-decoration: none;
      font-size: 0.9rem;
      font-weight: 500;
      transition: background 0.2s, color 0.2s;
    }
    .link-btn:hover { background: #2563eb; color: white; border-color: #2563eb; }
    .divider { border: none; border-top: 1px solid #1e2937; margin: 20px 0; }
    form { display: grid; gap: 18px; }
    .row-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; }
    label { display: grid; gap: 7px; color: #cbd5e1; font-weight: 600; font-size: 0.9rem; }
    input, select {
      width: 100%;
      padding: 12px 14px;
      border-radius: 12px;
      border: 1px solid #334155;
      background: #0f172a;
      color: #e2e8f0;
      font-size: 0.95rem;
      outline: none;
      transition: border-color 0.2s;
    }
    input:focus, select:focus { border-color: #2563eb; }
    .actions { display: flex; gap: 12px; margin-top: 8px; }
    .btn-primary {
      flex: 1; padding: 14px;
      border: none; border-radius: 12px;
      font-size: 1rem; font-weight: 600;
      background: #2563eb; color: white; cursor: pointer;
      transition: background 0.2s;
    }
    .btn-primary:hover { background: #1d4ed8; }
    .btn-secondary {
      padding: 14px 24px;
      border: 1px solid #334155; border-radius: 12px;
      font-size: 1rem; font-weight: 600;
      background: #1e293b; color: #cbd5e1; cursor: pointer;
      text-decoration: none; display: inline-flex; align-items: center;
      transition: background 0.2s;
    }
    .btn-secondary:hover { background: #334155; }
    .hint { color: #64748b; font-size: 0.83rem; margin-top: 12px; }
    @media (max-width: 560px) { .row-2 { grid-template-columns: 1fr; } }
  </style>
</head>
<body>
  <div class="page">
    <div class="form-card">
      <div class="card-header">
        <h1>Attendance</h1>
        <p>Mark attendance or view existing attendance records.</p>
      </div>

      <div class="quick-links">
        <a href="/admin/all-attendance" class="link-btn">View All Attendance</a>
        <a href="/admin/dashboardadmin" class="link-btn">Back to Dashboard</a>
      </div>

      <hr class="divider" />

      <form action="/admin/create-attendance" method="POST">

        <div class="row-2">
          <label>
            Class ID
            <input type="text" name="class_id" placeholder="Enter class object ID" required />
          </label>
          <label>
            Student ID
            <input type="text" name="student_id" placeholder="Enter student object ID" required />
          </label>
        </div>

        <div class="row-2">
          <label>
            Teacher ID
            <input type="text" name="teacher_id" placeholder="Enter teacher object ID" required />
          </label>
          <label>
            Marked By (Admin ID)
            <input type="text" name="marked_by" placeholder="Enter admin object ID" required />
          </label>
        </div>

        <div class="row-2">
          <label>
            Date
            <input type="date" name="date" required />
          </label>
          <label>
            Status
            <select name="status" required>
              <option value="present">Present</option>
              <option value="absent">Absent</option>
            </select>
          </label>
        </div>

        <label>
          Active
          <select name="is_active" required>
            <option value="true">Yes</option>
            <option value="false">No</option>
          </select>
        </label>

        <div class="actions">
          <a href="/admin/all-attendance" class="btn-secondary">Cancel</a>
          <button type="submit" class="btn-primary">Mark Attendance</button>
        </div>
      </form>

      <p class="hint">Use valid MongoDB object IDs for class, student, teacher, and admin fields.</p>
    </div>
  </div>
</body>
</html>
