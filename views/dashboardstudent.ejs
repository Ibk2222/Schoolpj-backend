<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Student Dashboard</title>
  <style>
    body { margin: 0; min-height: 100vh; font-family: 'Segoe UI', sans-serif; background: linear-gradient(135deg, #0f172a 0%, #111827 100%); color: #e2e8f0; }
    .page { display: flex; flex-wrap: wrap; align-items: stretch; gap: 24px; padding: 32px; justify-content: center; }
    .panel { width: min(280px, 100%); background: #111827; border: 1px solid #1f2937; border-radius: 28px; padding: 26px; box-shadow: 0 20px 60px rgba(15, 23, 42, 0.35); }
    .panel h1 { margin: 0 0 12px; font-size: 2rem; }
    .panel p { margin: 0; color: #94a3b8; line-height: 1.7; }
    .content { flex: 1 1 560px; display: grid; gap: 24px; }
    .card { background: rgba(15, 23, 42, 0.96); border: 1px solid #1f2937; border-radius: 28px; padding: 28px; }
    .card h2, .card h3 { margin-top: 0; }
    .profile-grid { display: grid; gap: 16px; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); }
    .profile-item { display: grid; gap: 6px; }
    .profile-item strong { color: #fff; }
    .actions { display: grid; gap: 16px; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); margin-top: 16px; }
    .button { display: inline-flex; justify-content: center; align-items: center; padding: 14px 18px; border-radius: 18px; background: #2563eb; color: #fff; text-decoration: none; font-weight: 700; }
    .button.secondary { background: #334155; }
    .button:hover { background: #1d4ed8; }
    .avatar { width: 100%; aspect-ratio: 1 / 1; object-fit: cover; border-radius: 24px; background: #0f172a; }
  </style>
</head>
<body>
  <div class="page">
    <aside class="panel">
      <h1>Student Area</h1>
      <p>Welcome to your student dashboard. Access your profile, update details, and keep track of your school data.</p>
      <% if (typeof student !== 'undefined' && student.image) { %>
        <img src="<%= student.image %>" alt="Profile photo" class="avatar" style="margin: 16px 0;" />
      <% } %>
      <form action="/students/upload" method="POST" enctype="multipart/form-data" style="margin: 12px 0;">
        <label style="display:grid; gap:6px; color:#94a3b8; font-size:0.85rem; font-weight:600;">
          Update Photo
          <input type="file" name="image" accept="image/*" style="color:#94a3b8; font-size:0.82rem;" />
        </label>
        <button type="submit" style="margin-top:10px; width:100%; padding:10px; border:none; border-radius:12px; background:#2563eb; color:white; font-weight:600; cursor:pointer;">Upload</button>
      </form>
      <div class="actions">
        <a class="button" href="/students/dashboardstudent">Overview</a>
        <a class="button secondary" href="/students/loginstudent">Logout</a>
        <a class="button secondary" href="/students/signupstudent">Edit Profile</a>
      </div>
    </aside>
    <main class="content">
      <div class="card">
        <h2>Good day, <%= student.firstname %> <%= student.lastname %></h2>
        <p>Here is a summary of your student profile. Use the links below to keep your information current and to return to the portal home.</p>
      </div>
      <div class="card profile-grid">
        <div class="profile-item">
          <strong>Email</strong>
          <span><%= student.email %></span>
        </div>
        <div class="profile-item">
          <strong>Age</strong>
          <span><%= student.age %></span>
        </div>
        <div class="profile-item">
          <strong>DOB</strong>
          <span><%= student.dob ? new Date(student.dob).toISOString().slice(0, 10) : 'Not provided' %></span>
        </div>
        <div class="profile-item">
          <strong>Gender</strong>
          <span><%= student.gender %></span>
        </div>
        <div class="profile-item">
          <strong>Address</strong>
          <span><%= student.address %></span>
        </div>
        <div class="profile-item">
          <strong>Parent Phone</strong>
          <span><%= student.parent_phone %></span>
        </div>
      </div>
      <div class="card">
        <h3>Student Actions</h3>
        <div class="actions">
          <a class="button" href="/students/dashboardstudent">Refresh</a>
          <a class="button secondary" href="/students/loginstudent">Sign Out</a>
          <a class="button secondary" href="/students/signupstudent">Update Profile</a>
        </div>
      </div>
    </main>
  </div>
</body>
</html>
