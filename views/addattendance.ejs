<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Add Attendance</title>
  <style>
    body { margin: 0; background: #0f172a; color: #e2e8f0; font-family: Inter, system-ui, sans-serif; }
    .page { min-height: 100vh; display: grid; place-items: center; padding: 24px; }
    .form-card { width: min(760px, 100%); background: #111827; border-radius: 24px; border: 1px solid #1e2937; padding: 32px; }
    h1 { margin: 0 0 18px; font-size: 2rem; }
    form { display: grid; gap: 16px; }
    label { display: grid; gap: 8px; color: #cbd5e1; font-weight: 600; }
    input, select { width: 100%; padding: 12px 14px; border-radius: 14px; border: 1px solid #334155; background: #0f172a; color: #e2e8f0; box-sizing: border-box; }
    button { width: 100%; padding: 14px; border: none; border-radius: 14px; font-size: 1rem; background: #2563eb; color: white; cursor: pointer; }
    button:hover { background: #1d4ed8; }
  </style>
</head>
<body>
  <div class="page">
    <div class="form-card">
      <h1>Add Attendance</h1>
      <form action="<%= formAction %>" method="POST">
        <label>
          Class
          <select name="class_id" required>
            <option value="">-- Select Class --</option>
            <% classes.forEach(c => { %>
              <option value="<%= c._id %>"><%= c.name %> (<%= c.academic_year %>)</option>
            <% }) %>
          </select>
        </label>
        <label>
          Student
          <select name="student_id" required>
            <option value="">-- Select Student --</option>
            <% students.forEach(s => { %>
              <option value="<%= s._id %>"><%= s.firstname %> <%= s.lastname %></option>
            <% }) %>
          </select>
        </label>
        <!-- <label>
          Teacher
          <select name="teacher_id" required>
            <option value="">-- Select Teacher --</option>
            <% teachers.forEach(t => { %>
              <option value="<%= t._id %>"><%= t.firstname %> <%= t.lastname %></option>
            <% }) %>
          </select>
        </label> -->
        <label>
          Date
          <input type="date" name="date" required />
        </label>
        <label>
          Marked By
          <select name="marked_by" required>
            <option value="">-- Select Teacher --</option>
            <% teachers.forEach(t => { %>
              <option value="<%= t._id %>"><%= t.firstname %> <%= t.lastname %></option>
            <% }) %>
          </select>
        </label>
        <label>
          Status
          <select name="status" required>
            <option value="present">Present</option>
            <option value="absent">Absent</option>
          </select>
        </label>
        <label>
          Active
          <select name="is_active">
            <option value="true">Yes</option>
            <option value="false">No</option>
          </select>
        </label>
        <button type="submit">Save Attendance</button>
      </form>
    </div>
  </div>
</body>
</html>
