<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Add Subject</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { background: #0f172a; color: #e2e8f0; font-family: 'Segoe UI', Inter, system-ui, sans-serif; min-height: 100vh; }
    .page { min-height: 100vh; display: grid; place-items: center; padding: 24px; }
    .form-card {
      width: min(780px, 100%);
      background: #111827;
      border-radius: 24px;
      border: 1px solid rgba(148, 163, 184, 0.12);
      padding: 36px 32px;
      box-shadow: 0 8px 32px rgba(0,0,0,0.4);
    }
    .card-header { margin-bottom: 28px; }
    .card-header h1 { font-size: clamp(1.4rem, 3vw, 2rem); font-weight: 700; color: #f1f5f9; }
    .card-header p { color: #94a3b8; font-size: 0.92rem; margin-top: 6px; }
    form { display: grid; gap: 20px; }
    .row-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; }
    .field-label { display: block; color: #cbd5e1; font-weight: 600; font-size: 0.9rem; margin-bottom: 10px; }
    select {
      width: 100%;
      padding: 12px 14px;
      border-radius: 12px;
      border: 1px solid #334155;
      background: #0f172a;
      color: #e2e8f0;
      font-size: 0.95rem;
      outline: none;
      transition: border-color 0.2s;
    }
    select:focus { border-color: #2563eb; }
    .checkbox-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
      gap: 10px;
    }
    .checkbox-item {
      display: flex;
      align-items: center;
      gap: 10px;
      background: #0f172a;
      border: 1px solid #334155;
      border-radius: 10px;
      padding: 10px 14px;
      cursor: pointer;
      transition: border-color 0.2s, background 0.2s;
    }
    .checkbox-item:hover { border-color: #2563eb; background: #0f172a; }
    .checkbox-item input[type="checkbox"] {
      width: 16px; height: 16px;
      accent-color: #2563eb;
      cursor: pointer;
      flex-shrink: 0;
    }
    .checkbox-item input[type="checkbox"]:checked + span { color: #60a5fa; }
    .checkbox-item span { font-size: 0.9rem; color: #cbd5e1; }
    .actions { display: flex; gap: 12px; margin-top: 8px; }
    .btn-primary {
      flex: 1; padding: 14px;
      border: none; border-radius: 12px;
      font-size: 1rem; font-weight: 600;
      background: #2563eb; color: white; cursor: pointer;
      transition: background 0.2s;
    }
    .btn-primary:hover { background: #1d4ed8; }
    .btn-secondary {
      padding: 14px 24px;
      border: 1px solid #334155; border-radius: 12px;
      font-size: 1rem; font-weight: 600;
      background: #1e293b; color: #cbd5e1; cursor: pointer;
      text-decoration: none; display: inline-flex; align-items: center;
      transition: background 0.2s;
    }
    .btn-secondary:hover { background: #334155; }
    .hint { color: #64748b; font-size: 0.83rem; margin-top: 12px; }
    @media (max-width: 560px) { .row-2 { grid-template-columns: 1fr; } }
  </style>
</head>
<body>
  <div class="page">
    <div class="form-card">
      <div class="card-header">
        <h1>Add Subjects</h1>
        <p>Check all subjects you want to add, then assign a class and teacher.</p>
      </div>

      <form action="<%= formAction %>" method="POST">

        <div>
          <span class="field-label">Subject Names <span style="color:#64748b; font-weight:400;">(select one or more)</span></span>
          <div class="checkbox-grid">
            <label class="checkbox-item"><input type="checkbox" name="subject_name" value="Mathematics" /><span>Mathematics</span></label>
            <label class="checkbox-item"><input type="checkbox" name="subject_name" value="English Language" /><span>English Language</span></label>
            <label class="checkbox-item"><input type="checkbox" name="subject_name" value="Basic Science" /><span>Basic Science</span></label>
            <label class="checkbox-item"><input type="checkbox" name="subject_name" value="Verbal Reasoning" /><span>Verbal Reasoning</span></label>
            <label class="checkbox-item"><input type="checkbox" name="subject_name" value="Quantitative Reasoning" /><span>Quantitative Reasoning</span></label>
            <label class="checkbox-item"><input type="checkbox" name="subject_name" value="Computer Science" /><span>Computer Science</span></label>
            <label class="checkbox-item"><input type="checkbox" name="subject_name" value="C.R.S" /><span>C.R.S</span></label>
            <label class="checkbox-item"><input type="checkbox" name="subject_name" value="Yoruba" /><span>Yoruba</span></label>
            <label class="checkbox-item"><input type="checkbox" name="subject_name" value="Civic Education" /><span>Civic Education</span></label>
            <label class="checkbox-item"><input type="checkbox" name="subject_name" value="Agricultural Science" /><span>Agricultural Science</span></label>
            <label class="checkbox-item"><input type="checkbox" name="subject_name" value="Civic Education" /><span>Civic Education</span></label>
            <label class="checkbox-item"><input type="checkbox" name="subject_name" value="IRS" /><span>IRS</span></label>
            <label class="checkbox-item"><input type="checkbox" name="subject_name" value="French" /><span>French</span></label>
         <label class="checkbox-item"><input type="checkbox" name="subject_name" value="Music" /><span>Music</span></label>
            <label class="checkbox-item"><input type="checkbox" name="subject_name" value="Fine Art" /><span>Fine Art</span></label>
          </div>
        </div>

        <div class="row-2">
          <div>
            <span class="field-label">Class</span>
            <select name="classes_id" required>
              <option value="" disabled selected>Select a class</option>
              <% classes.forEach(c => { %>
                <option value="<%= c._id %>"><%= c.name %> (<%= c.academic_year %>)</option>
              <% }) %>
            </select>
          </div>
          <div>
            <span class="field-label">Teacher</span>
            <select name="teachers_id" required>
              <option value="" disabled selected>Select a teacher</option>
              <% teachers.forEach(t => { %>
                <option value="<%= t._id %>"><%= t.firstname %> <%= t.lastname %></option>
              <% }) %>
            </select>
          </div>
        </div>

        <div>
          <span class="field-label">Status</span>
          <select name="is_active" required>
            <option value="true">Active</option>
            <option value="false">Inactive</option>
          </select>
        </div>

        <div class="actions">
          <a href="/admin/all-subjects" class="btn-secondary">Cancel</a>
          <button type="submit" class="btn-primary">Save Subjects</button>
        </div>
      </form>

      <p class="hint">Each checked subject will be saved as a separate record under the selected class and teacher.</p>
    </div>
  </div>
</body>
</html>
