<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Add Class</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { background: #0f172a; color: #e2e8f0; font-family: 'Segoe UI', Inter, system-ui, sans-serif; min-height: 100vh; }
    .page { min-height: 100vh; display: grid; place-items: center; padding: 24px; }
    .form-card {
      width: min(780px, 100%);
      background: #111827;
      border-radius: 24px;
      border: 1px solid rgba(148, 163, 184, 0.12);
      padding: 36px 32px;
      box-shadow: 0 8px 32px rgba(0,0,0,0.4);
    }
    .card-header { margin-bottom: 28px; }
    .card-header h1 { font-size: clamp(1.4rem, 3vw, 2rem); font-weight: 700; color: #f1f5f9; }
    .card-header p { color: #94a3b8; font-size: 0.92rem; margin-top: 6px; }
    form { display: grid; gap: 18px; }
    .row-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; }
    label { display: grid; gap: 7px; color: #cbd5e1; font-weight: 600; font-size: 0.9rem; }
    input, select {
      width: 100%;
      padding: 12px 14px;
      border-radius: 12px;
      border: 1px solid #334155;
      background: #0f172a;
      color: #e2e8f0;
      font-size: 0.95rem;
      outline: none;
      transition: border-color 0.2s;
    }
    input:focus, select:focus { border-color: #2563eb; }
    .checkbox-group { display: flex; flex-wrap: wrap; gap: 12px; padding: 4px 0; }
    .checkbox-group label {
      display: flex; align-items: center; gap: 8px;
      font-weight: 400; color: #cbd5e1; cursor: pointer;
    }
    .checkbox-group input[type="checkbox"] {
      width: 16px; height: 16px; accent-color: #2563eb; cursor: pointer;
    }
    .actions { display: flex; gap: 12px; margin-top: 8px; }
    .btn-primary {
      flex: 1; padding: 14px;
      border: none; border-radius: 12px;
      font-size: 1rem; font-weight: 600;
      background: #2563eb; color: white; cursor: pointer;
      transition: background 0.2s;
    }
    .btn-primary:hover { background: #1d4ed8; }
    .btn-secondary {
      padding: 14px 24px;
      border: 1px solid #334155; border-radius: 12px;
      font-size: 1rem; font-weight: 600;
      background: #1e293b; color: #cbd5e1; cursor: pointer;
      text-decoration: none; display: inline-flex; align-items: center;
      transition: background 0.2s;
    }
    .btn-secondary:hover { background: #334155; }
    .hint { color: #64748b; font-size: 0.83rem; margin-top: 12px; }
    @media (max-width: 560px) { .row-2 { grid-template-columns: 1fr; } }
  </style>
</head>
<body>
  <div class="page">
    <div class="form-card">
      <div class="card-header">
        <h1>Add New Class</h1>
        <p>Fill in the details below to create a class record.</p>
      </div>

      <form action="<%= formAction %>" method="POST">

        <label>
          Class Name
          <select name="name" required>
            <option value="" disabled selected>Select a class</option>
            <option value="PRIMARY ONE">PRIMARY ONE</option>
            <option value="PRIMARY TWO">PRIMARY TWO</option>
            <option value="PRIMARY THREE">PRIMARY THREE</option>
            <option value="PRIMARY FOUR">PRIMARY FOUR</option>
            <option value="PRIMARY FIVE">PRIMARY FIVE</option>
          </select>
        </label>

        <label>
          Students <span style="color:#64748b; font-weight:400;">(hold Ctrl / Cmd to select multiple)</span>
          <select name="student_id" multiple required style="min-height: 140px;">
            <% students.forEach(s => { %>
              <option value="<%= s._id %>"><%= s.firstname %> <%= s.lastname %></option>
            <% }) %>
          </select>
        </label>

        <label>
          Teacher
          <select name="teacher_id" required>
            <option value="" disabled selected>Select a teacher</option>
            <% teachers.forEach(t => { %>
              <option value="<%= t._id %>"><%= t.firstname %> <%= t.lastname %></option>
            <% }) %>
          </select>
        </label>

        <label>
          Academic Year
          <input type="text" name="academic_year" placeholder="e.g. 2024-2025" pattern="\d{4}-\d{4}" required />
        </label>

        <label>Schedule Days</label>
        <div class="checkbox-group">
          <label><input type="checkbox" name="schedule[days]" value="Monday" /> Monday</label>
          <label><input type="checkbox" name="schedule[days]" value="Tuesday" /> Tuesday</label>
          <label><input type="checkbox" name="schedule[days]" value="Wednesday" /> Wednesday</label>
          <label><input type="checkbox" name="schedule[days]" value="Thursday" /> Thursday</label>
          <label><input type="checkbox" name="schedule[days]" value="Friday" /> Friday</label>
          <label><input type="checkbox" name="schedule[days]" value="Saturday" /> Saturday</label>
        </div>

        <label>
          Schedule Time
          <input type="datetime-local" name="schedule[time]" required />
        </label>

        <label>
          Status
          <select name="is_active" required>
            <option value="true">Active</option>
            <option value="false">Inactive</option>
          </select>
        </label>

        <div class="actions">
          <a href="/admin/all-classes" class="btn-secondary">Cancel</a>
          <button type="submit" class="btn-primary">Save Class</button>
        </div>
      </form>

      <p class="hint">Use valid MongoDB object IDs for student and teacher fields.</p>
    </div>
  </div>
</body>
</html>
