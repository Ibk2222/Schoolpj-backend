<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Dashboard</title>
  <style>
    body { margin: 0; font-family: 'Segoe UI', sans-serif; background: #0b1220; color: #f8fafc; }
    .page { display: flex; min-height: 100vh; }
    .sidebar { width: 260px; background: #111827; padding: 28px; display: flex; flex-direction: column; gap: 18px; }
    .sidebar h1 { margin: 0; font-size: 1.8rem; }
    .sidebar a { color: #cbd5e1; text-decoration: none; padding: 12px 14px; border-radius: 14px; background: #111827; transition: background 0.2s ease; }
    .sidebar a:hover { background: #1f2937; }
    .content { flex: 1; padding: 36px; }
    .hero { display: flex; justify-content: space-between; flex-wrap: wrap; gap: 24px; align-items: flex-start; }
    .hero h2 { margin: 0; font-size: clamp(2rem, 2.4vw, 2.8rem); }
    .hero p { margin: 10px 0 0; color: #94a3b8; max-width: 640px; }
    .panel-card { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 20px; margin-top: 28px; }
    .card { background: #111827; border: 1px solid #1f2937; border-radius: 24px; padding: 28px; }
    .card h3 { margin: 0 0 16px; font-size: 1.1rem; }
    .card p { margin: 10px 0; line-height: 1.7; color: #cbd5e1; }
    .details p { margin: 12px 0; }
    .button-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 16px; margin-top: 16px; }
    .button { display: inline-flex; justify-content: center; align-items: center; padding: 14px 18px; border-radius: 14px; background: #2563eb; color: #fff; text-decoration: none; font-weight: 600; }
    .button.secondary { background: #334155; }
    .button:hover { background: #1d4ed8; }
  </style>
</head>
<body>
  <div class="page">
    <aside class="sidebar">
      <h1>Admin</h1>
      <a href="/admin/dashboardadmin">Overview</a>
      <a href="/admin/all-admins">Manage Admins</a>
      <a href="/admin/all-students">Manage Students</a>
      <a href="/admin/all-teachers">Manage Teachers</a>
      <a href="/admin/all-subjects">Manage Subjects</a>
      <a href="/admin/all-classes">Manage Classes</a>
      <a href="/admin/loginadmin">Logout</a>
    </aside>
    <main class="content">
      <section class="hero">
        <div>
          <h2>Welcome back, <%= admin.firstname %> <%= admin.lastname %></h2>
          <p>Manage your school operations from one place. Review admins, students, teachers, and core academic data in a single dashboard.</p>
        </div>
      </section>
      <div class="panel-card">
        <div class="card">
          <h3>Profile</h3>
          <div class="details">
            <p><strong>Email:</strong> <%= admin.email %></p>
            <p><strong>Age:</strong> <%= admin.age %></p>
            <p><strong>Phone:</strong> <%= admin.phone %></p>
            <p><strong>Admin ID:</strong> <%= admin._id %></p>
          </div>
        </div>
        <div class="card">
          <h3>Quick actions</h3>
          <div class="button-grid">
            <a class="button" href="/admin/all-admins">View Admins</a>
            <a class="button" href="/admin/all-students">View Students</a>
            <a class="button" href="/admin/all-teachers">View Teachers</a>
            <a class="button secondary" href="/admin/signupadmin">Create Admin</a>
          </div>
        </div>
      </div>
    </main>
  </div>
</body>
</html>
