<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Teacher Dashboard</title>
  <style>
    body { margin: 0; font-family: 'Segoe UI', sans-serif; background: #08101a; color: #eef2ff; }
    .page { min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 24px; }
    .card { width: min(900px, 100%); background: #111827; border: 1px solid #1f2937; border-radius: 28px; padding: 36px; box-shadow: 0 28px 64px rgba(0, 0, 0, 0.32); }
    h1 { margin: 0 0 12px; font-size: clamp(2rem, 3vw, 2.6rem); }
    p.lead { margin: 0 0 24px; color: #94a3b8; max-width: 720px; }
    .stats { display: grid; gap: 18px; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); margin-top: 24px; }
    .stat { background: #0f172a; border: 1px solid #1f2937; border-radius: 20px; padding: 18px; }
    .stat strong { display: block; margin-bottom: 8px; color: #fff; }
    .stat span { color: #cbd5e1; }
    .actions { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 16px; margin-top: 30px; }
    .button { text-decoration: none; display: inline-flex; justify-content: center; align-items: center; padding: 14px 18px; border-radius: 16px; background: #2563eb; color: #fff; font-weight: 600; }
    .button:hover { background: #1d4ed8; }
  </style>
</head>
<body>
  <div class="page">
    <div class="card">
      <h1>Teacher Dashboard</h1>
      <p class="lead">Welcome back, <%= teacher.title %> <%= teacher.firstname %> <%= teacher.lastname %>. Manage your classes, view schedules, and update your availability.</p>
      <div class="stats">
        <div class="stat">
          <strong>Email</strong>
          <span><%= teacher.email %></span>
        </div>
        <div class="stat">
          <strong>Age</strong>
          <span><%= teacher.age %></span>
        </div>
        <div class="stat">
          <strong>Phone</strong>
          <span><%= teacher.phone %></span>
        </div>
        <div class="stat">
          <strong>Joined</strong>
          <span><%= teacher.joined_in ? new Date(teacher.joined_in).toISOString().slice(0, 10) : 'Not available' %></span>
        </div>
      </div>
      <div class="actions">
        <a class="button" href="/teacher/all-classes">My classes</a>
        <a class="button" href="/teacher/all-timetables">Timetable</a>
        <a class="button" href="/teacher/logins">Logout</a>
      </div>
    </div>
  </div>
</body>
</html>
