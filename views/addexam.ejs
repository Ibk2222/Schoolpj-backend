<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Add Exam</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { background: #0f172a; color: #e2e8f0; font-family: 'Segoe UI', Inter, system-ui, sans-serif; min-height: 100vh; }
    .page { min-height: 100vh; display: grid; place-items: center; padding: 24px; }
    .form-card {
      width: min(780px, 100%);
      background: #111827;
      border-radius: 24px;
      border: 1px solid rgba(148, 163, 184, 0.12);
      padding: 36px 32px;
      box-shadow: 0 8px 32px rgba(0,0,0,0.4);
    }
    .card-header { margin-bottom: 28px; }
    .card-header h1 { font-size: clamp(1.4rem, 3vw, 2rem); font-weight: 700; color: #f1f5f9; }
    .card-header p { color: #94a3b8; font-size: 0.92rem; margin-top: 6px; }
    form { display: grid; gap: 18px; }
    .row-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; }
    .row-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 18px; }
    label { display: grid; gap: 7px; color: #cbd5e1; font-weight: 600; font-size: 0.9rem; }
    input, select {
      width: 100%;
      padding: 12px 14px;
      border-radius: 12px;
      border: 1px solid #334155;
      background: #0f172a;
      color: #e2e8f0;
      font-size: 0.95rem;
      outline: none;
      transition: border-color 0.2s;
    }
    input:focus, select:focus { border-color: #2563eb; }
    .actions { display: flex; gap: 12px; margin-top: 8px; }
    .btn-primary {
      flex: 1; padding: 14px;
      border: none; border-radius: 12px;
      font-size: 1rem; font-weight: 600;
      background: #2563eb; color: white; cursor: pointer;
      transition: background 0.2s;
    }
    .btn-primary:hover { background: #1d4ed8; }
    .btn-secondary {
      padding: 14px 24px;
      border: 1px solid #334155; border-radius: 12px;
      font-size: 1rem; font-weight: 600;
      background: #1e293b; color: #cbd5e1; cursor: pointer;
      text-decoration: none; display: inline-flex; align-items: center;
      transition: background 0.2s;
    }
    .btn-secondary:hover { background: #334155; }
    .hint { color: #64748b; font-size: 0.83rem; margin-top: 12px; }
    @media (max-width: 640px) { .row-2, .row-3 { grid-template-columns: 1fr; } }
  </style>
</head>
<body>
  <div class="page">
    <div class="form-card">
      <div class="card-header">
        <h1>Add New Exam</h1>
        <p>Fill in the details below to create an exam record.</p>
      </div>

      <form action="/admin/create-exam" method="POST">

        <div class="row-2">
          <label>
            Student
            <select name="student_id" required>
              <option value="" disabled selected>Select a student</option>
              <% students.forEach(s => { %>
                <option value="<%= s._id %>"><%= s.firstname %> <%= s.lastname %></option>
              <% }) %>
            </select>
          </label>
          <label>
            Class
            <select name="class_id" required>
              <option value="" disabled selected>Select a class</option>
              <% classes.forEach(c => { %>
                <option value="<%= c._id %>"><%= c.name %> (<%= c.academic_year %>)</option>
              <% }) %>
            </select>
          </label>
        </div>

        <div class="row-2">
          <label>
            Subject
            <select name="subject_id" required>
              <option value="" disabled selected>Select a subject</option>
              <% subjects.forEach(s => { %>
                <option value="<%= s._id %>"><%= s.subject_name %></option>
              <% }) %>
            </select>
          </label>
          <label>
            Teacher
            <select name="teacher_id" required>
              <option value="" disabled selected>Select a teacher</option>
              <% teachers.forEach(t => { %>
                <option value="<%= t._id %>"><%= t.firstname %> <%= t.lastname %></option>
              <% }) %>
            </select>
          </label>
        </div>

        <label>
          Grade Level
          <input type="text" name="grade_level" placeholder="e.g. JSS1, SSS2" required />
        </label>

        <div class="row-3">
          <label>
            Score
            <input type="number" name="score" placeholder="0" min="0" required />
          </label>
          <label>
            Max Score
            <input type="number" name="max_score" placeholder="100" min="1" required />
          </label>
          <label>
            Passing Score
            <input type="number" name="passing_score" placeholder="50" min="0" required />
          </label>
        </div>

        <div class="row-2">
          <label>
            Start Date
            <input type="date" name="start_date" required />
          </label>
          <label>
            End Date
            <input type="date" name="end_date" required />
          </label>
        </div>

        <label>
          Status
          <select name="is_active" required>
            <option value="true">Active</option>
            <option value="false">Inactive</option>
          </select>
        </label>

        <div class="actions">
          <a href="/admin/all-exams" class="btn-secondary">Cancel</a>
          <button type="submit" class="btn-primary">Save Exam</button>
        </div>
      </form>

      <p class="hint">All dropdowns are populated from the database.</p>
    </div>
  </div>
</body>
</html>
