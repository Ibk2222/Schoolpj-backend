<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Manage Timetables</title>
  <style>
    body { margin: 0; background: #07101a; color: #eef2ff; font-family: Inter, system-ui, sans-serif; }
    .shell { max-width: 1220px; margin: 0 auto; padding: 28px; }
    header { display: flex; flex-wrap: wrap; justify-content: space-between; align-items: center; gap: 16px; }
    h1 { margin: 0; font-size: clamp(2rem, 3vw, 2.6rem); }
    .button { padding: 12px 18px; background: #8b5cf6; color: white; border-radius: 14px; text-decoration: none; font-weight: 700; }
    .button:hover { background: #7c3aed; }
    .card { margin-top: 24px; background: rgba(15, 23, 42, 0.96); border-radius: 24px; border: 1px solid rgba(148, 163, 184, 0.16); overflow: hidden; }
    table { width: 100%; border-collapse: collapse; }
    th, td { padding: 16px 18px; border-bottom: 1px solid rgba(148, 163, 184, 0.12); }
    th { text-transform: uppercase; letter-spacing: 0.12em; font-size: 0.8rem; color: #94a3b8; }
    td { color: #e2e8f0; font-size: 0.95rem; }
    .note { color: #94a3b8; font-size: 0.86rem; }
    .actions a { color: #fbbf24; text-decoration: none; margin-right: 10px; }
    .actions a:hover { text-decoration: underline; }
    .empty { padding: 40px; text-align: center; color: #94a3b8; }
  </style>
</head>
<body>
  <div class="shell">
    <header>
      <div>
        <h1>Manage Timetables</h1>
        <p style="margin: 8px 0 0; color: #94a3b8;">Monitor schedule entries, rooms, and class times.</p>
      </div>
      <a class="button" href="/admin/addtimetable">Add Timetable</a>
    </header>
    <div class="card">
      <% if (timetables && timetables.length) { %>
      <table>
        <thead>
          <tr>
            <th>Class</th>
            <th>Teacher</th>
            <th>Subject</th>
            <th>Day</th>
            <th>Time</th>
            <th>Room</th>
            <th>Year</th>
            <th>Active</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% timetables.forEach(item => { %>
          <tr>
            <td><%= item.class || '-' %></td>
            <td><%= item.teacher || '-' %></td>
            <td><%= item.subject || '-' %></td>
            <td><%= item.day_of_week %></td>
            <td class="note"><%= item.start_time %> - <%= item.end_time %></td>
            <td><%= item.room %></td>
            <td><%= item.academic_year %></td>
            <td class="note"><%= item.is_active ? 'Yes' : 'No' %></td>
            <td class="actions">
              <a href="/admin/edit-timetable/<%= item._id %>">Edit</a>
              <a href="/admin/delete-timetable/<%= item._id %>">Delete</a>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
      <% } else { %>
      <div class="empty">No timetable entries available.</div>
      <% } %>
    </div>
  </div>
</body>
</html>
